# AI Keys
GEMINI_API_KEY=your_gemini_api_key_here
# Optional (default: gemini-3-flash-preview)
GEMINI_MODEL=gemini-3-flash-preview
# Optional (default: models/text-embedding-004)
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# Vector Database (Pinecone via code)
# Backend supports both VECTOR_* and PINECONE_* env var names.
VECTOR_DB_API_KEY=your_pinecone_key
VECTOR_DB_INDEX=your_pinecone_index_name
# Optional: only needed if your Pinecone client requires host/environment
PINECONE_HOST=
PINECONE_ENVIRONMENT=
# Optional
VECTOR_DB_NAMESPACE=

# Query tuning (optional)
VECTOR_QUERY_TOP_K=8
VECTOR_QUERY_DIMENSION=1536

# Risk report query tuning (optional)
RISK_REPORT_QUERY=recent OWASP vulnerabilities and security incidents
RISK_REPORT_TOP_K=200

# Backend Config
PORT=8001
DEBUG=True

# Frontend Config (must match BE reachable URL)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8001
